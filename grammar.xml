<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/print.xsl" ?>
<?xml-stylesheet type="text/css" href="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/rules.css" title="Easy editing stylesheet" ?>
<rules lang="tl" xsi:noNamespaceSchemaLocation="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <category id="GRAMATIKA" name="Gramatika at Ortograpiya">
        <!-- rule 1 -->
        <rule id="IKA_AT_NUMERO" name="Gitling sa unlaping 'ika-' at numero">
            <pattern>
                <token>ika</token>
                <token regexp="yes">\d+</token>
            </pattern>
            <message>Ayon sa Ortograpiyang Pambansa (11.8), ginagamit ang gitling kapag inilalapi ang 'ika-' sa tambilang.</message>
            <suggestion>ika-<match no="2"/></suggestion>
            <example correction="ika-5">Siya ay ang <marker>ika 5</marker> na dumating.</example>
            <example>Siya ay ang ika-5 na dumating.</example>
        </rule>
        <!-- rule 2 -->
        <rule id="E_TO_I_HULAPI" name="Pagpapalit ng E tungo sa I kapag may hulapi na '-han'">
            <pattern>
                <token regexp="yes">(?i)(kababae|kape|garahe|sige|diskarte)(han)</token>
            </pattern>
            <message>Ayon sa Ortograpiyang Pambansa (7.4), ang 'e' sa dulo ng salitang-ugat ay nagiging 'i' kapag hinuhulapian ng '-han'.</message>
            <suggestion><match no="1" regexp_match="(?i)(.*)e(han)" regexp_replace="$1i$2"/></suggestion>
            <example correction="kababaihan">Maraming <marker>kababaehan</marker> ang dumalo sa seminar.</example>
            <example correction="kapihan">May masarap na <marker>kapehan</marker> sa Antipolo.</example>
            <example>Maraming kababaihan ang dumalo sa seminar.</example>
            <example>May masarap na kapihan sa Antipolo.</example>
        </rule>
        <!-- rule 3 -->
        <rule id="DAW_DIN_KATINIG" name="Daw/Din pagkatapos ng Katinig">
            <pattern>
                <token regexp="yes">.*[bcdfghjklmnpqrstvxz]$<exception regexp="yes" scope="current">^[A-Z]+$</exception></token>
                <token regexp="yes">raw|rin|rito|roon|riyan</token>
            </pattern>
            <message>Ayon sa Ortograpiyang Pambansa (8.1), nananatiling 'd' (daw/din) kapag ang sinusundang salita ay nagtatapos sa katinig maliban sa 'w' at 'y'.</message>
            <suggestion><match no="1"/> <match no="2" regexp_match="^r" regexp_replace="d"/></suggestion>
            <example correction="umalis daw">Sinabi niya na <marker>umalis raw</marker> siya kahapon.</example>
            <example correction="kumain din">Gusto niyang <marker>kumain rin</marker>.</example>
            <example>Sinabi niya na umalis daw siya kahapon.</example>
            <example>Gusto niyang kumain din.</example>
        </rule>
    </category>

</rules>